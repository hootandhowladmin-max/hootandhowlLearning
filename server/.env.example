# Firebase Configuration
FIREBASE_PROJECT_ID=hhadmin

# Copy your Firebase service account key file to this directory
# and name it serviceAccountKey.json

# Email Configuration (Choose ONE: SendGrid OR SMTP)
# Option 1: SendGrid (RECOMMENDED for Render)
# 1. Sign up at https://sendgrid.com
# 2. Create an API key with "Mail Send" permissions
# 3. Verify your sender email in SendGrid (Single Sender Verification)
# SENDGRID_API_KEY=your-sendgrid-api-key
# Optional: Custom From address
# SMTP_FROM="Hoot & Howl Learning" <your-email@example.com>

# Option 2: Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# Optional: Custom From address (defaults to SMTP_USER if not set)
# SMTP_FROM="Hoot & Howl Learning" <your-email@gmail.com>
